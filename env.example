# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgres://postgres.[YOUR_DATABASE]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations.
DIRECT_URL="postgres://postgres.[YOUR_DATABASE]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="你的 Supabase Project URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="你的 Supabase anon public key"

# Better Auth
BETTER_AUTH_SECRET="secret_key"
# 认证服务地址（推荐与当前站点一致；分站部署可单独指定 auth 子域）
NEXT_PUBLIC_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# 可选：将聊天/语音 API 指向单独子域；不填则默认走当前域名同源 /api
# NEXT_PUBLIC_API_URL=""

# Google ID and sersect
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

#qq邮箱发信
QQ_SMTP_HOST=smtp.qq.com
QQ_SMTP_PORT=465
QQ_SMTP_USER=你的QQ邮箱@qq.com
QQ_SMTP_PASS=你刚拿到的SMTP授权码

# Cloudflare Turnstile（注册验证码）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=你的Turnstile站点公钥
TURNSTILE_SECRET_KEY=你的Turnstile密钥

# Stripe 支付（Sponsor）
STRIPE_SECRET_KEY=你的Stripe服务端密钥
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=你的Stripe前端公钥
STRIPE_WEBHOOK_SECRET=你的Stripe Webhook签名密钥
